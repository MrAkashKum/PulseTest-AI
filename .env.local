# PulseTest-AI runtime configuration
# This file lives at the project root.
# Copy it to `.env.local` before starting local development.
# All values below are examples. Replace only the secret values you actually use.

# -----------------------------------------------------------------------------
# Public app settings
# -----------------------------------------------------------------------------

# Public app URL used in docs, health output and deployment references.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OpenAI server settings
# -----------------------------------------------------------------------------

# Required for shared/server-side generation.
# Keep this secret on the server or in Vercel Environment Variables.
OPENAI_API_KEY=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

# Recommended: set this explicitly for the model available to your account.
# Change this if your account does not have access to gpt-5.5.
OPENAI_MODEL=gpt-5.4

# Speed controls. `medium` is a good balance for everyday use.
OPENAI_REASONING_EFFORT=medium
OPENAI_RESEARCH_REASONING_EFFORT=medium
OPENAI_SEARCH_CONTEXT_SIZE=medium
OPENAI_RESEARCH_CONTEXT_SIZE=medium

